generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  SUPPORTER
  JUDGE
  MODERATOR
  ADMIN
}

enum MessageConversationKind {
  DIRECT
  ORGANIZER
}

enum CompetitionStage {
  ROUND_1
  ROUND_2
  ROUND_3
}

enum SubmissionRound {
  ROUND_2
  ROUND_3
}

enum TeamRound1LockStatus {
  OPEN
  PENDING
  LOCKED
  DECLINED
}

enum TeamFinalOutcome {
  CHAMPION
  RUNNER_UP
  THIRD_PLACE
  FOURTH_PLACE
  EMERGING_TEAM
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum LeadershipTransferStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum Round1TeamLockRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum Round1TestBankType {
  OBJECTIVE
  ESSAY
}

enum Round1QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum Round1QuestionType {
  TRUE_FALSE
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  PAIRING
  ESSAY
}

enum Round1BankStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Round1AttemptStatus {
  IN_PROGRESS
}

enum Round1JudgeReviewSource {
  AI
  HUMAN
}

enum TeamSubmissionJudgeReviewSource {
  AI
  HUMAN
}

enum Round1AiEssayScoringStatus {
  NOT_STARTED
  SCORING
  SCORED
  FAILED
  SKIPPED_HUMAN
}

enum Round1AiEssayScoringJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Round1AiEssayScoringJobMode {
  RUN_ALL
  RETRY_FAILED
}

enum Round2AiReportScoringStatus {
  NOT_STARTED
  SCORING
  SCORED
  FAILED
  SKIPPED_HUMAN
}

enum Round2AiReportScoringJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Round2AiReportScoringJobMode {
  RUN_ALL
  RETRY_FAILED
}

enum EmergingAiReportScoringJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum EmergingAiReportScoringJobMode {
  RUN_ALL
  RETRY_FAILED
}

enum TeamSubmissionResourceSource {
  EXTERNAL
  UPLOAD
}

enum UserActionTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ForumThreadCategory {
  LOOKING_FOR_TEAM
  TEAM_LOOKING_FOR_MEMBERS
  GENERAL_DISCUSSION
}

enum ForumThreadStatus {
  OPEN
  CLOSED
}

model User {
  id                         String                      @id @default(cuid())
  loginId                    String                      @unique @default(cuid())
  email                      String                      @unique
  emailVerifiedAt            DateTime?
  passwordHash               String?
  name                       String
  role                       UserRole                    @default(STUDENT)
  studentId                  String?                     @unique
  phoneNumber                String?
  university                 String                      @default("")
  major                      String                      @default("")
  classYear                  String                      @default("")
  bio                        String                      @default("")
  avatarTone                 String                      @default("from-sky-500 via-cyan-400 to-emerald-400")
  avatarImageSrc             String?
  judgeProfileId             String?                     @unique
  supporterReferralCode      String?                     @unique
  referredByCode             String?
  referredBySupporterId      String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  accounts                   Account[]
  sessions                   Session[]
  teamMembership             TeamMember?
  ledTeams                   Team[]                      @relation("TeamLeader")
  declinedLocks              Team[]                      @relation("DeclinedRound1Lock")
  sentInvitations            TeamInvitation[]            @relation("InvitationSender")
  receivedInvites            TeamInvitation[]            @relation("InvitationRecipient")
  messageParticipations      MessageParticipant[]
  sentMessages               DirectMessage[]             @relation("DirectMessageSender")
  sentTransfers              LeadershipTransferRequest[] @relation("TransferSender")
  receivedTransfers          LeadershipTransferRequest[] @relation("TransferRecipient")
  sentLockRequests           Round1TeamLockRequest[]     @relation("Round1LockSender")
  receivedLockRequests       Round1TeamLockRequest[]     @relation("Round1LockRecipient")
  round1ExamAttempt          Round1ExamAttempt?
  round1Submissions          Round1Submission[]
  teamSubmissions            TeamSubmission[]
  round1JudgeReviews         Round1JudgeReview[]
  teamSubmissionJudgeReviews TeamSubmissionJudgeReview[]
  round2TeamJudgeAssignments Round2TeamJudgeAssignment[]
  actionTokens               UserActionToken[]
  forumThreads               ForumThread[]               @relation("ForumThreadAuthor")
  forumReplies               ForumReply[]                @relation("ForumReplyAuthor")
  referredBySupporter        User?                       @relation("SupporterReferrals", fields: [referredBySupporterId], references: [id], onDelete: SetNull)
  referredUsers              User[]                      @relation("SupporterReferrals")

  @@index([referredBySupporterId])
  @@index([referredByCode])
}

model UserActionToken {
  id         String              @id @default(cuid())
  userId     String
  email      String
  type       UserActionTokenType
  tokenHash  String              @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([email, type, createdAt])
}

model Team {
  id                         String                      @id @default(cuid())
  name                       String
  tag                        String                      @unique
  leaderId                   String
  stage                      CompetitionStage            @default(ROUND_1)
  finalOutcome               TeamFinalOutcome?
  finalScore                 Float?
  finalScoreUpdatedAt        DateTime?
  round1LockStatus           TeamRound1LockStatus        @default(OPEN)
  round1LockProtocolId       String?
  round1LockRequestedAt      DateTime?
  round1LockedAt             DateTime?
  round1LockDeclinedAt       DateTime?
  round1LockDeclinedByUserId String?
  avatarTone                 String
  avatarImageSrc             String?
  track                      String
  bio                        String
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  leader                     User                        @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  declinedByUser             User?                       @relation("DeclinedRound1Lock", fields: [round1LockDeclinedByUserId], references: [id], onDelete: SetNull)
  members                    TeamMember[]
  invitations                TeamInvitation[]
  leadershipTransferRequests LeadershipTransferRequest[]
  round1LockRequests         Round1TeamLockRequest[]
  round1ExamAttempts         Round1ExamAttempt[]
  round1Submissions          Round1Submission[]
  submissions                TeamSubmission[]
  round2JudgeAssignments     Round2TeamJudgeAssignment[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvitation {
  id          String               @id @default(cuid())
  teamId      String
  fromUserId  String
  toUserId    String
  status      TeamInvitationStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  respondedAt DateTime?
  team        Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser    User                 @relation("InvitationSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User                 @relation("InvitationRecipient", fields: [toUserId], references: [id], onDelete: Cascade)
}

model MessageConversation {
  id              String                  @id @default(cuid())
  kind            MessageConversationKind @default(DIRECT)
  requesterId     String?
  organizerReadAt DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  lastMessageAt   DateTime                @default(now())
  participants    MessageParticipant[]
  messages        DirectMessage[]

  @@index([lastMessageAt])
  @@index([kind, requesterId])
}

model MessageParticipant {
  id             String              @id @default(cuid())
  conversationId String
  userId         String
  readAt         DateTime?
  hiddenAt       DateTime?
  showOtherEmail Boolean             @default(false)
  createdAt      DateTime            @default(now())
  conversation   MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String              @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  deletedAt      DateTime?
  deletedByName  String?
  createdAt      DateTime            @default(now())
  conversation   MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([deletedAt])
}

model LeadershipTransferRequest {
  id          String                   @id @default(cuid())
  teamId      String
  fromUserId  String
  toUserId    String
  status      LeadershipTransferStatus @default(PENDING)
  createdAt   DateTime                 @default(now())
  respondedAt DateTime?
  team        Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser    User                     @relation("TransferSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User                     @relation("TransferRecipient", fields: [toUserId], references: [id], onDelete: Cascade)
}

model Round1TeamLockRequest {
  id          String                      @id @default(cuid())
  protocolId  String
  teamId      String
  fromUserId  String
  toUserId    String
  status      Round1TeamLockRequestStatus @default(PENDING)
  createdAt   DateTime                    @default(now())
  respondedAt DateTime?
  team        Team                        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser    User                        @relation("Round1LockSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User                        @relation("Round1LockRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([teamId, protocolId])
}

model Round1TestBank {
  id                  String              @id @default(cuid())
  slug                String              @unique
  bankType            Round1TestBankType
  status              Round1BankStatus    @default(DRAFT)
  titleEn             String
  titleVi             String
  descriptionEn       String
  descriptionVi       String
  questionPoolSize    Int
  questionsPerAttempt Int
  shuffleQuestions    Boolean             @default(true)
  shuffleOptions      Boolean             @default(true)
  durationMinutes     Int
  wordLimit           Int?
  fixedEssayPromptEn  String              @default("")
  fixedEssayPromptVi  String              @default("")
  publishedAt         DateTime?
  questions           String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  attempts            Round1ExamAttempt[]
  submissions         Round1Submission[]
}

model Round1ExamAttempt {
  id                   String              @id @default(cuid())
  bankId               String
  teamId               String
  userId               String              @unique
  status               Round1AttemptStatus @default(IN_PROGRESS)
  startedAt            DateTime
  deadlineAt           DateTime
  currentQuestionIndex Int                 @default(0)
  questions            String
  answers              String              @default("{}")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  bank                 Round1TestBank      @relation(fields: [bankId], references: [id], onDelete: Restrict)
  team                 Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, deadlineAt])
  @@index([deadlineAt])
}

model Round1Submission {
  id              String              @id @default(cuid())
  bankId          String
  teamId          String
  userId          String
  submittedAt     DateTime            @default(now())
  rightCount      Int
  wrongCount      Int
  score           Float
  objectiveScore  Int
  essayScore      Float?
  totalScore      Float?
  durationMinutes Int
  answers         String?
  bank            Round1TestBank      @relation(fields: [bankId], references: [id], onDelete: Restrict)
  team            Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  judgeReviews    Round1JudgeReview[]
  aiEssayReview   Round1AiEssayReview?

  @@unique([userId])
  @@index([teamId, submittedAt])
}

model TeamSubmission {
  id                 String                       @id @default(cuid())
  teamId             String
  round              SubmissionRound
  version            Int
  title              String
  summary            String
  resourceSource     TeamSubmissionResourceSource
  resourceLabel      String
  resourceUrl        String?
  resourceStorageKey String?
  resourceMimeType   String?
  resourceSizeBytes  Int?
  submittedByUserId  String
  submittedAt        DateTime                     @default(now())
  team               Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submittedByUser    User                         @relation(fields: [submittedByUserId], references: [id], onDelete: Restrict)
  judgeReviews       TeamSubmissionJudgeReview[]
  aiReportReview     Round2AiReportReview?

  @@unique([teamId, round, version])
}

model Round1JudgeReview {
  id           String           @id @default(cuid())
  judgeUserId  String
  submissionId String
  score        Float?
  note         String           @default("")
  source       Round1JudgeReviewSource @default(HUMAN)
  scoredAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  judgeUser    User             @relation(fields: [judgeUserId], references: [id], onDelete: Cascade)
  submission   Round1Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([judgeUserId, submissionId])
  @@index([judgeUserId, scoredAt])
}

model Round1AiEssayReview {
  id                String                      @id @default(cuid())
  submissionId      String                      @unique
  judgeUserId       String?
  model             String                      @default("")
  status            Round1AiEssayScoringStatus @default(NOT_STARTED)
  score             Float?
  questionScores    String                      @default("{}")
  questionComments  String                      @default("{}")
  note              String                      @default("")
  error             String?
  scoredAt          DateTime?
  humanOverriddenAt DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  submission        Round1Submission            @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model Round1AiEssayScoringJob {
  id                String                         @id @default(cuid())
  mode              Round1AiEssayScoringJobMode
  status            Round1AiEssayScoringJobStatus @default(PENDING)
  model             String                         @default("")
  totalEligible     Int                            @default(0)
  processedCount    Int                            @default(0)
  scoredCount       Int                            @default(0)
  failedCount       Int                            @default(0)
  skippedHumanCount Int                            @default(0)
  skippedExistingCount Int                         @default(0)
  lastError         String?
  createdByUserId   String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  @@index([status, createdAt])
}

model TeamSubmissionJudgeReview {
  id           String         @id @default(cuid())
  judgeUserId  String
  submissionId String
  score        Float?
  note         String         @default("")
  source       TeamSubmissionJudgeReviewSource @default(HUMAN)
  scoredAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  judgeUser    User           @relation(fields: [judgeUserId], references: [id], onDelete: Cascade)
  submission   TeamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([judgeUserId, submissionId])
  @@index([judgeUserId, scoredAt])
}

model Round2AiReportReview {
  id                String                      @id @default(cuid())
  submissionId      String                      @unique
  model             String                      @default("")
  status            Round2AiReportScoringStatus @default(NOT_STARTED)
  score             Float?
  rubricScores      String                      @default("{}")
  comment           String                      @default("")
  error             String?
  scoredAt          DateTime?
  humanOverriddenAt DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  submission        TeamSubmission              @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model Round2AiReportScoringJob {
  id                   String                         @id @default(cuid())
  mode                 Round2AiReportScoringJobMode
  status               Round2AiReportScoringJobStatus @default(PENDING)
  model                String                         @default("")
  totalEligible        Int                            @default(0)
  processedCount       Int                            @default(0)
  scoredCount          Int                            @default(0)
  failedCount          Int                            @default(0)
  skippedHumanCount    Int                            @default(0)
  skippedExistingCount Int                            @default(0)
  lastError            String?
  createdByUserId      String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  @@index([status, createdAt])
}

model EmergingAiReportScoringJob {
  id                   String                           @id @default(cuid())
  mode                 EmergingAiReportScoringJobMode
  status               EmergingAiReportScoringJobStatus @default(PENDING)
  model                String                           @default("")
  totalEligible        Int                              @default(0)
  processedCount       Int                              @default(0)
  scoredCount          Int                              @default(0)
  failedCount          Int                              @default(0)
  skippedHumanCount    Int                              @default(0)
  skippedExistingCount Int                              @default(0)
  lastError            String?
  createdByUserId      String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt

  @@index([status, createdAt])
}

model Round2TeamJudgeAssignment {
  id          String   @id @default(cuid())
  teamId      String
  judgeUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  judgeUser   User     @relation(fields: [judgeUserId], references: [id], onDelete: Cascade)

  @@unique([teamId, judgeUserId])
  @@index([judgeUserId])
}

model NewsPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  categoryEn      String
  categoryVi      String
  titleEn         String
  titleVi         String
  excerptEn       String
  excerptVi       String
  author          String
  publishedAt     DateTime
  readTime        String
  coverLabelEn    String
  coverLabelVi    String
  coverImageSrc   String
  coverImageAltEn String
  coverImageAltVi String
  highlights      String
  content         String
  tags            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ForumThread {
  id             String              @id @default(cuid())
  slug           String              @unique
  authorId       String
  title          String
  summary        String
  body           String
  category       ForumThreadCategory
  status         ForumThreadStatus   @default(OPEN)
  university     String
  preferredRoles String              @default("[]")
  contactNote    String              @default("")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lastActivityAt DateTime            @default(now())
  editedAt       DateTime?
  editedByName   String?
  author         User                @relation("ForumThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies        ForumReply[]

  @@index([category, status, lastActivityAt])
  @@index([authorId, createdAt])
}

model ForumReply {
  id            String      @id @default(cuid())
  threadId      String
  authorId      String
  body          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  editedAt      DateTime?
  editedByName  String?
  deletedAt     DateTime?
  deletedByName String?
  thread        ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author        User        @relation("ForumReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model CmsEntry {
  id        String   @id @default(cuid())
  scope     String   @unique
  payload   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
